{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "資產管理儀表板",
  "version": "0.1.1",
  "identifier": "com.shiauka.asset-dashboard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run vite:dev",
    "beforeBuildCommand": "npm run vite:build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "資產管理儀表板",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app"],
    "icon": ["icons/icon.ico"]
  }
}
